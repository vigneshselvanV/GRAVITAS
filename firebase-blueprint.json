{
  "collections": [
    {
      "name": "tasks",
      "path": "tasks/{taskId}",
      "description": "Stores user tasks",
      "permissions": [
        {
          "role": "owner",
          "operations": ["create", "read", "update", "delete"],
          "condition": "request.auth != null && request.auth.uid == resource.data.user_id"
        },
        {
          "role": "creator",
          "operations": ["create"],
          "condition": "request.auth != null && request.resource.data.user_id == request.auth.uid"
        }
      ],
      "fields": [
        { "name": "title", "type": "string" },
        { "name": "description", "type": "string" },
        { "name": "deadline", "type": "string", "optional": true },
        { "name": "effort_hours", "type": "number", "optional": true },
        { "name": "priority_score", "type": "number", "optional": true },
        { "name": "category", "type": "string", "optional": true },
        { "name": "urgency_label", "type": "string", "optional": true },
        { "name": "tags", "type": "list", "optional": true },
        { "name": "status", "type": "string" },
        { "name": "plan", "type": "map", "optional": true },
        { "name": "nudge_level", "type": "number", "optional": true },
        { "name": "last_activity", "type": "timestamp", "optional": true },
        { "name": "created_at", "type": "timestamp" },
        { "name": "user_id", "type": "string" }
      ]
    },
    {
      "name": "nudges",
      "path": "tasks/{taskId}/nudges/{nudgeId}",
      "description": "Stores nudges generated by the agent",
      "permissions": [
        {
          "role": "reader",
          "operations": ["read"],
          "condition": "request.auth != null"
        }
      ],
      "fields": [
        { "name": "nudge_level", "type": "number" },
        { "name": "tone", "type": "string" },
        { "name": "message", "type": "string" },
        { "name": "action_required", "type": "string" },
        { "name": "time_remaining_label", "type": "string" },
        { "name": "created_at", "type": "timestamp" }
      ]
    }
  ]
}
